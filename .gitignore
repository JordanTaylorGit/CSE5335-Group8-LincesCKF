# Node.js / React / macOS common ignores

# dependencies
node_modules/
/**/node_modules/

# testing
coverage/
.nyc_output/

# production
build/
dist/
out/

# local env files
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
.jscoverage

# macOS
.DS_Store
.AppleDouble
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor directories and files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Editor swap/temp files
*~
*.swp
.#*

# Parcel/Babel cache
.cache
.parcel-cache

# Next.js
.next/

# Vercel
.vercel/

# Netlify
.netlify/

# Firebase
.firebase/


# Svelte
/.svelte-kit/

# TypeScript
*.tsbuildinfo

# Optional npm cache directory
.npm

# Yarn v2 Plug'n'Play
.pnp.cjs
.pnp.js

# Lock files (usually committed) - do NOT ignore unless you want to
# package-lock.json
# yarn.lock

# OS generated files
*.orig

# Database files
*.sqlite
*.sqlite3
db.sqlite

# Debugger
.vscode/launch.json

# Client-specific
/client/build/
/client/dist/
/client/.parcel-cache/



# Keep examples in repo: ignore env files but not .env.example
!/.env.example

